#!/bin/bash
# LocalPreview.app 启动器
# 双击 = 启动本地站点并打开浏览器；再次双击 = 停止
PROJ="$(cd "$(dirname "$0")/../../.." && pwd)"
PIDFILE="$PROJ/.local-preview.pid"
LOG="$PROJ/.local-preview.log"
URL="http://127.0.0.1:3000"

# 用绝对路径（Finder 双击时 PATH 极简，找不到 npm/node）
NODE="/Users/duoqian/.workbuddy/binaries/node/versions/22.22.2/bin/node"
NPM="/Users/duoqian/.workbuddy/binaries/node/versions/22.22.2/bin/npm"
BIN_DIR="$(dirname "$NODE")"
export PATH="$BIN_DIR:$PATH"

# 若已在运行（PID 文件存在且进程存活）→ 停止
if [ -f "$PIDFILE" ]; then
  PID=$(cat "$PIDFILE")
  if kill -0 "$PID" 2>/dev/null; then
    echo "停止本地预览..."
    kill "$PID" 2>/dev/null
    sleep 1
    pkill -f "vite --port=3000" 2>/dev/null
    pkill -f "node server.js" 2>/dev/null
    pkill -f "npm run server" 2>/dev/null
    pkill -f "npm run dev" 2>/dev/null
    pkill -f "node start.js" 2>/dev/null
    rm -f "$PIDFILE"
    osascript -e 'display notification "本地预览已停止" with title "Gemosdodo 本地预览"' 2>/dev/null
    exit 0
  else
    # PID 文件残留但进程已死 → 清理后重新启动
    rm -f "$PIDFILE"
  fi
fi

# 启动（用绝对路径的 npm，避免 Finder 环境找不到）
cd "$PROJ"
nohup "$NPM" start > "$LOG" 2>&1 &
echo $! > "$PIDFILE"

# 轮询等待服务就绪（最多 30 秒）
echo "等待本地站点启动..."
for i in $(seq 1 30); do
  sleep 1
  if curl --noproxy '*' -s -m 2 -o /dev/null -w "%{http_code}" "$URL" 2>/dev/null | grep -q "200\|304"; then
    echo "站点就绪 (${i}s)"
    open "$URL"
    osascript -e "display notification \"本地预览已启动 → ${URL}\" with title \"Gemosdodo 本地预览\"" 2>/dev/null
    exit 0
  fi
done

# 超时：仍尝试打开（可能部分功能可用）
echo "启动超时，尝试打开浏览器..."
open "$URL"
osascript -e 'display notification "本地预览可能还在加载，请稍候刷新" with title "Gemosdodo 本地预览"' 2>/dev/null
exit 0
