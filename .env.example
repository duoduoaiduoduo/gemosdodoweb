# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_SECRET: Required for admin write APIs (timeline/assets create/update/delete).
ADMIN_SECRET="CHANGE_ME_TO_A_STRONG_SECRET"

# MAX_UPLOAD_MB: Maximum size per uploaded file (0 = unlimited). Applies after decode.
MAX_UPLOAD_MB="10"

# MAX_REQUEST_MB: Express JSON body size limit (MB). Admin uploads use base64 in JSON (~4/3 of file size).
# Example: a 200MB PDF needs about 270MB request body — set 400 or higher, or uploads fail / "Failed to fetch".
MAX_REQUEST_MB="400"

# MAX_PDF_UPLOAD_MB: Max PDF file size when multipart upload is used (default 600). Ignored when MAX_UPLOAD_MB > 0.
MAX_PDF_UPLOAD_MB="600"

# TRUST_PROXY_HOPS: Express trust proxy hops for real client IP extraction.
TRUST_PROXY_HOPS="1"

# IP2REGION local DB paths (offline region lookup by IP).
IP2REGION_IPV4_DB="./node_modules/ip2region/data/ip2region.db"
IP2REGION_IPV6_DB="./node_modules/ip2region/data/ipv6wry.db"

# Set to "1" to disable IPv6 lookup and only use IPv4 DB.
IP2REGION_DISABLE_IPV6="0"
